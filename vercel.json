{
  "version": 2,
  "builds": [
    {
      "src": "Client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "Server/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Server/app.js"
    },
    {
      "src": "/health",
      "dest": "Server/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "Client/$1"
    }
  ]
}
